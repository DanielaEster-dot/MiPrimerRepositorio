Algoritmo SumaYResta
	Definir num1, num2, suma, resta Como Entero
	
	Escribir "Ingresar el primer número"
	Leer num1
	
	Escribir "Ingresar el segundo número"
	Leer num2
	
	suma = num1 + num2
	resta = num1 - num2
	
	Escribir "Resultado de la sunma es:", suma
	Escribir "Resultado de la resta es:", resta
	
FinAlgoritmo
