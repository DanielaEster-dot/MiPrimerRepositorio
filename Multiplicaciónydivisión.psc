Algoritmo ProductoYCociente
	Definir num1, num2, producto, cociente Como Real
	
	Escribir "Ingresar el primer número"
	Leer num1
	
	Escribir "Ingresar el segundo número"
	Leer num2
	
	producto = num1 * num2
	cociente = num1 / num2
	
	Escribir "Resultado del producto es:", producto
	Escribir "Resultado del cociente es:", cociente
	
FinAlgoritmo
