Algoritmo Comparaciones
	Definir num1, num2 Como Entero
	
	Escribir "Ingresar primer número"
	Leer num1
	
	Escribir "Ingresar segundo número"
	Leer num2
	
	Si num1 > num2  Entonces
		Escribir num1, ">", num2
	SiNo
		Si num1 < num2 Entonces
			Escribir num1 "<", num2
		SiNo
			Escribir num1, "=", num2
		Fin Si
	Fin Si
	
FinAlgoritmo
